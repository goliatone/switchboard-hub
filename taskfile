##
## build
##
## Build the TimeSlice binary
##
function go:build {
    go:build:versioned "$@"
}

##
## -----
##
## go:build:versioned
##
## Build binary with version/build metadata from .version + git.
##
## Arguments:
## @arg 1 {string} [output=./bin/$BINAME]
## @arg 2 {string} [build_tags=$BUILD_TAGS]
##
function go:build:versioned {
    lgr I "Building project..."

    local output=${1:-"./bin/$BINAME"}
    local cli_build_tags=${2}
    local active_build_tags="${cli_build_tags:-${BUILD_TAGS:-}}"
    local git_commit
    local git_tag
    local build_date
    local app_version
    local ldflags
    local -a tags_args

    version:check
    app_version=$(version:get)
    git_commit=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
    git_tag=$(git describe --tags --always --dirty 2>/dev/null || echo "v${app_version}")
    build_date=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    ldflags="-s -w"
    ldflags+=" -X main.version=${app_version}"
    ldflags+=" -X main.commit=${git_commit}"
    ldflags+=" -X main.buildDate=${build_date}"
    ldflags+=" -X main.buildTags=${active_build_tags}"
    ldflags+=" -X main.gitTag=${git_tag}"

    tags_args=()
    if [[ -n "${active_build_tags}" ]]; then
        tags_args=(-tags "${active_build_tags}")
        lgr I "Using build tags: ${active_build_tags}"
    fi

    mkdir -p "$(dirname "$output")"

    # Add -s and -w flags to strip debug info and reduce binary size, which helps with linker issues
    # TODO: DO WE NEED CGO ENABLED?!
    CGO_ENABLED=1 go build "${tags_args[@]}" -ldflags "$ldflags" -o "$output" ./cmd/$BINAME

    if [ $? -eq 0 ]; then
        lgr OK "Version: ${app_version} (${git_commit})"
        lgr OK "Binary built: $output"
    else
        lgr E "Build failed"
        return 1
    fi
}

##
## -----
##
## install:local
##
## Install ts binary to /usr/local/bin (requires sudo)
##
function install:local {
    local build_path="./bin/$BINAME"
    local install_path="/usr/local/bin/$BINAME"
    local alias_name="sbd"
    local alias_path="/usr/local/bin/$alias_name"

    lgr I "Installing $BINAME to /usr/local/bin..."

    # Build the binary first
    go:build "$build_path"
    if [ $? -ne 0 ]; then
        lgr E "Build failed, installation aborted"
        return 1
    fi

    if ! sudo install -m 0755 "$build_path" "$install_path"; then
        lgr E "Install failed - could not write $install_path"
        return 1
    fi

    if ! sudo ln -sfn "$install_path" "$alias_path"; then
        lgr E "Install failed - could not create alias $alias_path"
        return 1
    fi

    lgr OK "$BINAME installed to /usr/local/bin"
    lgr OK "$alias_name alias installed to /usr/local/bin"

    # Verify installation and print version metadata from installed binary
    if [ ! -x "$install_path" ]; then
        lgr E "Installation failed - $install_path is missing or not executable"
        return 1
    fi

    if [ ! -L "$alias_path" ]; then
        lgr E "Installation failed - $alias_path is not a symlink"
        return 1
    fi

    if ! command -v "$BINAME" &> /dev/null; then
        lgr E "Installation failed - $BINAME not found in PATH"
        return 1
    fi

    if ! command -v "$alias_name" &> /dev/null; then
        lgr E "Installation failed - $alias_name not found in PATH"
        return 1
    fi

    lgr I "Installation verified - $BINAME is available globally"
    if ! "$install_path" version; then
        lgr E "Installation failed - could not execute $install_path"
        return 1
    fi

    if ! "$alias_path" version; then
        lgr E "Installation failed - could not execute $alias_path"
        return 1
    fi
}

##
## ########################################
##           Version Management
## ########################################

##
## -----
##
## version:upsert
##
## Save version to meta file.
## First time will create file if not present
##
## Arguments:
## @arg 1 {string} [tag=0.0.1]
function version:upsert {
    local tag=${1}

    if [ -z "$tag" ]; then
        version:get
    else
        version:set "$tag"
        version:get
    fi
}

##
## -----
##
## version:get
##
## Get version from meta file.
function version:get {

    test -f "${VERSION_FILE}" || touch "${VERSION_FILE}"

    local tag
    tag=$(cat "${VERSION_FILE}")

    if [ -z "$tag" ]; then
        tag="0.0.1"
        version:set "$tag"
    fi

    echo -n "$tag"
}

##
## -----
##
## version:set
##
## Set and save version to meta file.
## First time will create file if not present.
##
## Arguments:
## @arg 1 {string} [tag=0.0.1]
function version:set {

    local tag
    tag=${1}
    if [ -z "$tag" ]; then
        exit 1
    fi

    version:check

    echo -e "$tag" > "${VERSION_FILE}"
}

##
## -----
##
## version:bump
## Bump sem ver by specifying a level.
## Valid levels are:
## - patch (default)
## - minor
## - major
##
## If you want to update the .version file
## pass the `--write` flag.
## @see https://github.com/fsaintjacques/semver-tool/blob/master/src/semver
##
## @arg 1 {string} [level=patch]
## Outputs:
##   Semver string "$major.$minor.$patch"
##
## @flag --write Will write to .version file
##
function version:bump {

    version:check

    # Default values
    level='patch'
    write_to_file=0

    # Parse options
    while [[ "$#" -gt 0 ]]; do
        case $1 in
            --write)
                write_to_file=1
                shift
            ;;
            patch|minor|major)
                level=$1
                shift
            ;;
            *)
                echo "Invalid option: $1"
                return 2
            ;;
        esac
    done

    # Read contents of version and store in
    IFS='.' read -ra identifiers < "$VERSION_FILE"

    [[ "${#identifiers[@]}" -ne 3 ]] && echo "Invalid semver string" && return 1

    patch=${identifiers[2]}
    minor=${identifiers[1]}
    major=${identifiers[0]}

    case $level in
        patch)
            patch=$((patch+1))
        ;;
        minor)
            minor=$((minor+1))
            patch=0
        ;;
        major)
            major=$((major+1))
            minor=0
            patch=0
        ;;
        *)
            echo "Invalid level passed"
            return 2
    esac

    new_version="$major.$minor.$patch"

    if [[ $write_to_file -eq 1 ]]; then
        echo "$new_version" > "${VERSION_FILE}"
    else
        echo "$new_version"
    fi
}

function version:check {
    if [ ! -f "$VERSION_FILE" ]; then
        echo "0.0.0" > "$VERSION_FILE"
    fi
}


##
## -----
##
## release
##
## Bump our current version, create a git tag
## and push to trigger our release flow.
##
## Arguments:
## @arg 1 {string} [level=patch]
##        Accepted major, minor, patch
function release {
    local tag
    local level
    local message
    local current_branch

    current_branch=$(git rev-parse --abbrev-ref HEAD)
    if [[ "${current_branch}" != "${GIT_MAIN}" ]]; then
        lgr E "Release must run on ${GIT_MAIN}; current branch is ${current_branch}"
        exit 1
    fi

    if [ -n "$(git status --porcelain -uno)" ]; then
        echo "error: cannot pull with rebase: You have unstaged changes."
        echo "error: please commit or stash them."
        exit 1
    fi

    # Fetch all changes from origin
    git fetch --all
    # Make sure we have the latest version file
    git checkout origin/main -- ".version"

    # Pull tags to make sure we have
    git pull --tags -f

    level=${1:-"patch"}

    # Bump our version
    tag=$(version:bump "${level}")

    # Set message: default to New major|minor|patch release: vx.x.x
    message=${2:-"New ${level} release: v${tag}"}

    # Update version file
    version:set "${tag}"

    # Add updated version file to git
    git add "${VERSION_FILE}"
    git commit -m "Bump version: v${tag}"

    # Create a new tag
    git tag -a "v${tag}" -m "${message}"

    # Push tags and trigger release 🚀 🥳
    git push --tags
    git push

    # Generate changelog
    git cliff --output CHANGELOG.md
    git add CHANGELOG.md
    git commit -m "docs: update changelog for v${tag}"

    git push
}

